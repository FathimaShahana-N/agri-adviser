{
  "name": "agri-adviser",
  "version": "0.1.0",
  "description": "AgriAdvisor - multilingual multi-agent chat assistant for smallholder farmers",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
