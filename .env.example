PORT=3000

# Agent 2 - Diagnosis Agent (Plant.id)
PLANT_ID_API_KEY=

# Set to "true" to skip real Plant.id API calls during development and
# return a saved sample response instead (no API credits used).
MOCK_PLANT_ID=false
# Which saved sample to return when MOCK_PLANT_ID=true:
# high_confidence | low_confidence | out_of_scope
MOCK_PLANT_ID_SCENARIO=high_confidence

# Agent 3 - Weather Agent (OpenWeatherMap)
OPENWEATHER_API_KEY=

# Set to "true" to skip real OpenWeatherMap API calls during development and
# return a saved sample response instead (no API credits used).
MOCK_WEATHER=false
# Which saved sample to return when MOCK_WEATHER=true: high_risk | normal
MOCK_WEATHER_SCENARIO=normal
